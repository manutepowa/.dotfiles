# General
confirm-close-surface = false
gtk-single-instance = true
shell-integration-features = no-cursor

# Theme
theme = One Half Dark
background = #1C1C1C

# Cursor
# cursor-invert-fg-bg = true
cursor-color = #CCC
cursor-text = #000
cursor-style = block_hollow
cursor-style-blink = false

# Window
# window-theme = system
gtk-titlebar = false
window-width = 160
window-height = 75
window-save-state = always
quick-terminal-position = right
gtk-tabs-location = bottom
gtk-wide-tabs = false

# No funciona en gtk
# window-position-x = 486
# window-position-y = 127

# Font
font-family = Geist Mono
font-family-italic = Geist Mono Italic
font-family-bold = Geist Mono Bold
font-family-bold-italic = Geist Mono Bold Italic
# font-style = Regular
font-size = 12
adjust-cell-height = 20%
adjust-cell-width = -10%

# Mouse
mouse-hide-while-typing = true

# Clipboard
copy-on-select = clipboard

# Keybinds
keybind = ctrl+shift+o=unbind
keybind = alt+9=reload_config
keybind = alt+p=paste_from_clipboard

# ----------------------------------------
# HERDR COPY MODE + GHOSTTY MODAL KEYBINDS
# ----------------------------------------

# F4 entra en copy mode de Herdr y, al mismo tiempo,
# activa una tabla modal en Ghostty.
keybind = unconsumed:f4=activate_key_table:herdr-copy


# Dentro de copy mode:
# Alt+K = 5 líneas arriba
# Alt+J = 5 líneas abajo
keybind = herdr-copy/alt+k=text:\x1b[A\x1b[A\x1b[A\x1b[A\x1b[A
keybind = herdr-copy/alt+j=text:\x1b[B\x1b[B\x1b[B\x1b[B\x1b[B


# Al salir de copy mode con Esc, Ghostty también sale de la tabla modal.
keybind = herdr-copy/unconsumed:escape=deactivate_key_table

# Alternativas habituales de salida, por si Herdr también acepta q o Enter.
keybind = herdr-copy/unconsumed:q=deactivate_key_table
keybind = herdr-copy/unconsumed:enter=deactivate_key_table
