agent/mcp-cache.json

# Session data
agent/sessions/

# Dependencies (managed by pi itself)
agent/npm/
agent/package.json
agent/pnpm-lock.yaml

# IPC runtime files
agent/intercom/

# Local databases (frecency, history)
agent/pi-pretty/
