{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode-go/deepseek-v4-pro",
  "agent": {
    "m3-agent": {
      "mode": "all",
      "description": "M3 Agent - Safe proposal mode without auto-execution",
      "prompt": "{file:./M3_AGENT.md}",
      "tools": {
        "read": true,
        "write": true,
        "edit": true,
        "bash": true
      }
    }
  },
  "autoshare": false,
  "autoupdate": true,
  "default_agent": "m3-agent",
  "disabled_providers": [
    "gemini"
  ],
  "lsp": {
    "typescript": {
      "command": [
        "typescript-language-server",
        "--stdio"
      ],
      "disabled": false
    }
  },
  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest"
      ],
      "enabled": false
    },
    "context7": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@upstash/context7-mcp"
      ],
      "enabled": false
    },
    "engram": {
      "command": [
        "engram",
        "mcp",
        "--tools=agent"
      ],
      "enabled": true,
      "type": "local"
    },
    "next-devtools": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "next-devtools-mcp@latest"
      ],
      "enabled": false
    },
    "web-reader": {
      "type": "remote",
      "url": "https://api.z.ai/api/mcp/web_reader/mcp",
      "headers": {
        "Authorization": "{env:ANTHROPIC_AUTH_TOKEN}"
      },
      "enabled": false
    },
    "web-search-prime": {
      "type": "remote",
      "url": "https://api.z.ai/api/mcp/web_search_prime/mcp",
      "headers": {
        "Authorization": "{env:ANTHROPIC_AUTH_TOKEN}"
      },
      "enabled": false
    },
    "zai-mcp-server": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@z_ai/mcp-server"
      ],
      "environment": {
        "Z_AI_API_KEY": "{env:ANTHROPIC_AUTH_TOKEN}",
        "Z_AI_MODE": "ZAI"
      },
      "enabled": false
    }
  }
}
